{
  "name": "@ishaan_gpt/smoothrecord-worker",
  "version": "0.2.1",
  "description": "SmoothRecord recorder worker — turns any website into a premium smooth-scroll MP4.",
  "type": "module",
  "bin": {
    "smoothrecord-worker": "src/pair.js",
    "smoothrecord": "src/pair.js",
    "smoothrecord-pair": "src/pair.js",
    "smoothrecord-server": "src/server.js"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "pair": "node src/pair.js",
    "postinstall": "playwright install chromium"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "fastify": "^5.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "nanoid": "^5.0.9",
    "playwright": "1.49.1",
    "say": "^0.16.0",
    "unzipper": "^0.12.3",
    "zod": "^3.23.8"
  }
}
